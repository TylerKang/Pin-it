{
  "name": "pin-it",
  "productName": "Pin-It — Sticky Note Board",
  "version": "1.0.0",
  "description": "A digital pegboard with sticky notes",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "npm run build && electron .",
    "dist:mas": "npm run build && electron-builder --mac mas --universal",
    "dist:debug": "npm run build && electron-builder --mac dmg --universal",
    "cap:sync": "npm run build && cap sync ios",
    "ios:open": "cap open ios"
  },
  "dependencies": {
    "firebase": "^10.13.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/ios": "^6.1.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.devsky.pinit",
    "productName": "Pin-It — Sticky Note Board",
    "copyright": "Copyright © 2026 DevSky. All rights reserved.",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "darkModeSupport": true,
      "minimumSystemVersion": "12.0",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        }
      ]
    },
    "mas": {
      "category": "public.app-category.productivity",
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "provisioningProfile": "PinIt_AppStore.provisionprofile",
      "target": [
        {
          "target": "mas",
          "arch": ["universal"]
        }
      ]
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
