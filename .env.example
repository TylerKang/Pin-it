# Copy to .env.local (gitignored) and fill in values from the Firebase
# console → Project Settings → General → Your apps → Web app config.
# Web SDK config is not "secret" in the traditional sense (Firebase
# documents this), but we keep it out of git for environment portability.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Sentry — get DSN from Sentry → Settings → Projects → Pin-It → Client Keys
VITE_SENTRY_DSN=
