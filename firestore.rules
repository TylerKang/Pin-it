rules_version = '2';

// Firestore security rules for Pin-It Board.
//
// Paste into Firebase console → Firestore → Rules and Publish.
//
// Model:
//   /boards/{boardId}                         → { ownerUids[], createdAt, updatedAt }
//   /boards/{boardId}/notes/{noteId}          → serialized note + `order`
//   /syncCodes/{code}                         → { boardId, createdBy, expiresAt, used }
//
// Threat model:
//   - All clients are anonymous Firebase Auth.
//   - boardId == an anonymous auth UID (~128 bits of entropy) →
//     enumeration of board IDs is not feasible.
//   - Sync codes are 6 chars from a 32-char alphabet (~30 bits), single-
//     use, 10-min TTL → brute-forcing is not feasible at SDK rate limits.
//   - We rely on boardId unguessability as the security floor for board
//     reads and pair-in writes (see comments below).

service cloud.firestore {
  match /databases/{database}/documents {

    match /boards/{boardId} {
      // Any authenticated user can read board metadata. The notes
      // subcollection (below) remains restricted to listed ownerUids.
      // This relaxation is required so the joining device can verify
      // the board exists before redeeming a pairing code.
      allow read: if request.auth != null;

      // Create: caller must be the board's intended sole owner.
      allow create: if request.auth != null
                    && request.auth.uid == boardId
                    && request.resource.data.ownerUids == [request.auth.uid];

      // Update — two valid paths:
      //   1. Existing owner doing normal updates (preserves other owners).
      //   2. Non-owner joining via pairing: can add ONLY themselves to
      //      ownerUids, must preserve all existing owners, must grow the
      //      array by exactly 1.
      allow update: if request.auth != null
                    && (
                      (request.auth.uid in resource.data.ownerUids
                       && request.resource.data.ownerUids.hasAll(
                            resource.data.ownerUids.removeAll([request.auth.uid])
                          ))
                      ||
                      (!(request.auth.uid in resource.data.ownerUids)
                       && request.auth.uid in request.resource.data.ownerUids
                       && request.resource.data.ownerUids.hasAll(resource.data.ownerUids)
                       && request.resource.data.ownerUids.size() == resource.data.ownerUids.size() + 1)
                    );

      // No delete from clients.
      allow delete: if false;

      // Per-note subcollection — strict: only listed ownerUids may
      // read/write/delete. The boardId metadata may be readable by all
      // auth users, but actual note content stays restricted.
      match /notes/{noteId} {
        function isOwner() {
          return request.auth != null
            && exists(/databases/$(database)/documents/boards/$(boardId))
            && request.auth.uid in
               get(/databases/$(database)/documents/boards/$(boardId)).data.ownerUids;
        }
        allow read, write, delete: if isOwner();
      }
    }

    match /syncCodes/{code} {
      // Anyone authenticated can read a code (to pair).
      allow read: if request.auth != null;

      // Create: createdBy == caller, used starts false, expiresAt within 15 min.
      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.used == false
                    && request.resource.data.expiresAt > request.time
                    && request.resource.data.expiresAt < request.time + duration.value(15, 'm');

      // Update — only allowed to mark used=true (single-use). After that the
      // doc is immutable.
      allow update: if request.auth != null
                    && resource.data.used == false
                    && request.resource.data.used == true
                    && request.resource.data.usedBy == request.auth.uid;

      // No deletes.
      allow delete: if false;
    }
  }
}
